{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "outDir": "out",
    "baseUrl": ".",
    "types": ["node"],
    "esModuleInterop": true
  },
  "include": ["electron/**/*.ts"],
  "exclude": ["src", "node_modules", "out"]
}
