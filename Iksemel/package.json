{
  "name": "iksemel",
  "version": "0.1.0",
  "main": "out/main/index.js",
  "description": "Iksemel — Build optimised XML filters and XSLT transformations for WHATS'ON broadcast exports",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:wdyr": "vite --mode wdyr",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src e2e vite.config.ts vitest.config.ts playwright.config.ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:golden": "vitest run src/engine/generation/xslt-golden.test.ts",
    "test:golden:update": "UPDATE_GOLDEN=true vitest run src/engine/generation/xslt-golden.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:electron": "playwright test --config playwright.electron.config.ts",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "dev:electron": "electron-vite dev",
    "build:electron": "electron-vite build",
    "preview:electron": "electron-vite preview",
    "dist:win": "npm run build:electron && electron-builder --win --config electron-builder.config.ts",
    "dist:mac": "npm run build:electron && electron-builder --mac --config electron-builder.config.ts"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@open-policy-agent/opa-wasm": "^1.10.0",
    "@playwright/test": "^1.49.1",
    "@tanstack/react-virtual": "^3.13.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.13.10",
    "@types/oracledb": "^6.10.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "electron": "^33.4.11",
    "electron-builder": "^26.9.0",
    "electron-vite": "^3.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fflate": "^0.8.2",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.11",
    "monaco-editor": "^0.55.1",
    "oracledb": "^6.10.0",
    "pg": "^8.20.0",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.css": [
      "prettier --write"
    ]
  }
}
